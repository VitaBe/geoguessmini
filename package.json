{
  "name": "geoguessmini",
  "version": "1.0.0",
  "description": "A fully client-side location guessing game",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jszip": "^3.10.1",
    "papaparse": "^5.4.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": [
      "js/**/*.js"
    ],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  }
}
